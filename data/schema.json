{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Bab Bhagawad Gita",
  "type": "object",
  "required": ["bab", "judul", "jumlah_sloka", "sumber", "sloka"],
  "additionalProperties": false,
  "properties": {
    "bab": {
      "type": "integer",
      "minimum": 1,
      "maximum": 18
    },
    "judul": {
      "type": "object",
      "required": ["sanskrit", "id", "ban"],
      "additionalProperties": false,
      "properties": {
        "sanskrit": { "type": "string" },
        "id": { "type": "string" },
        "ban": { "type": ["string", "null"] }
      }
    },
    "jumlah_sloka": {
      "type": "integer",
      "minimum": 1
    },
    "sumber": {
      "type": "object",
      "required": ["sanskrit", "terjemahan_id", "terjemahan_ban"],
      "additionalProperties": false,
      "properties": {
        "sanskrit": { "type": "string" },
        "terjemahan_id": { "type": "string" },
        "terjemahan_ban": { "type": "string" }
      }
    },
    "sloka": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["no", "devanagari", "iast", "id", "ban", "status", "catatan"],
        "additionalProperties": false,
        "properties": {
          "no": { "type": "integer", "minimum": 1 },
          "devanagari": { "type": "string" },
          "iast": { "type": "string" },
          "id": { "type": "string" },
          "ban": { "type": ["string", "null"] },
          "status": {
            "type": "object",
            "required": ["id", "ban"],
            "additionalProperties": false,
            "properties": {
              "id": { "enum": ["kosong", "draf", "review", "final"] },
              "ban": { "enum": ["kosong", "draf", "review", "final"] }
            }
          },
          "catatan": { "type": "string" }
        }
      }
    }
  }
}
