{
  "bab": 2,
  "judul": {
    "sanskrit": "Sāṅkhya-yoga",
    "id": "Sāṅkhya Yoga (Yoga Pengetahuan)",
    "ban": null
  },
  "jumlah_sloka": 72,
  "sumber": {
    "sanskrit": "Gita Supersite, IIT Kanpur — Śrīmad Bhagavadgītā, Bab 2",
    "terjemahan_id": "Draf editorial proyek, diterjemahkan langsung dari teks Sanskrit; perlu telaah ahli sebelum publikasi.",
    "terjemahan_ban": ""
  },
  "sloka": [
    {
      "no": 1,
      "devanagari": "सञ्जय उवाच । तं तथा कृपयाविष्टमश्रुपूर्णाकुलेक्षणम् । विषीदन्तमिदं वाक्यमुवाच मधुसूदनः ॥ २.१ ॥",
      "iast": "sañjaya uvāca | taṃ tathā kṛpayāviṣṭam aśrupūrṇākulekṣaṇam | viṣīdantam idaṃ vākyam uvāca madhusūdanaḥ || 2.1 ||",
      "id": "Sañjaya berkata: Kepada Arjuna yang demikian diliputi belas kasihan, dengan mata penuh air mata dan hati yang muram, Madhusūdana mengucapkan kata-kata ini.",
      "ban": null,
      "status": {
        "id": "draf",
        "ban": "kosong"
      },
      "catatan": ""
    },
    {
      "no": 2,
      "devanagari": "श्रीभगवानुवाच । कुतस्त्वा कश्मलमिदं विषमे समुपस्थितम् । अनार्यजुष्टमस्वर्ग्यमकीर्तिकरमर्जुन ॥ २.२ ॥",
      "iast": "śrībhagavān uvāca | kutas tvā kaśmalam idaṃ viṣame samupasthitam | anāryajuṣṭam asvargyam akīrtikaram arjuna || 2.2 ||",
      "id": "Śrī Bhagavān bersabda: Dari mana datang kelemahan yang mengotori dirimu pada saat genting ini, Arjuna? Itu tidak layak bagi pribadi mulia, tidak mengantar ke surga, dan membawa aib.",
      "ban": null,
      "status": {
        "id": "draf",
        "ban": "kosong"
      },
      "catatan": ""
    },
    {
      "no": 3,
      "devanagari": "क्लैब्यं मा स्म गमः पार्थ नैतत्त्वय्युपपद्यते । क्षुद्रं हृदयदौर्बल्यं त्यक्त्वोत्तिष्ठ परन्तप ॥ २.३ ॥",
      "iast": "klaibyaṃ mā sma gamaḥ pārtha naitat tvayy upapadyate | kṣudraṃ hṛdayadaurbalyaṃ tyaktvottiṣṭha paraṃtapa || 2.3 ||",
      "id": "Jangan menyerah pada kepengecutan, Pārtha; itu tidak pantas bagimu. Tinggalkan kelemahan hati yang hina itu; bangkitlah, penakluk musuh.",
      "ban": null,
      "status": {
        "id": "draf",
        "ban": "kosong"
      },
      "catatan": ""
    },
    {
      "no": 4,
      "devanagari": "अर्जुन उवाच । कथं भीष्ममहं सङ्ख्ये द्रोणं च मधुसूदन । इषुभिः प्रतियोत्स्यामि पूजार्हावरिसूदन ॥ २.४ ॥",
      "iast": "arjuna uvāca | kathaṃ bhīṣmam ahaṃ saṅkhye droṇaṃ ca madhusūdana | iṣubhiḥ pratiyotsyāmi pūjārhāv arisūdana || 2.4 ||",
      "id": "Arjuna berkata: Wahai Madhusūdana, bagaimana aku dapat bertempur dengan panah melawan Bhīṣma dan Droṇa di medan perang, padahal keduanya patut kuhormati, wahai penghancur musuh?",
      "ban": null,
      "status": {
        "id": "draf",
        "ban": "kosong"
      },
      "catatan": ""
    },
    {
      "no": 5,
      "devanagari": "गुरूनहत्वा हि महानुभावान् श्रेयो भोक्तुं भैक्ष्यमपीह लोके । हत्वार्थकामांस्तु गुरूनिहैव भुञ्जीय भोगान् रुधिरप्रदिग्धान् ॥ २.५ ॥",
      "iast": "gurūn ahatvā hi mahānubhāvān śreyo bhoktuṃ bhaikṣyam apīha loke | hatvārthakāmāṃs tu gurūn ihaiva bhuñjīya bhogān rudhirapradigdhān || 2.5 ||",
      "id": "Lebih baik aku hidup mengemis di dunia ini daripada membunuh para guru yang agung itu. Jika membunuh mereka, kenikmatan dan harta yang kunikmati di sini akan berlumur darah.",
      "ban": null,
      "status": {
        "id": "draf",
        "ban": "kosong"
      },
      "catatan": ""
    },
    {
      "no": 6,
      "devanagari": "न चैतद्विद्मः कतरन्नो गरीयो यद्वा जयेम यदि वा नो जयेयुः । यानेव हत्वा न जिजीविषामस्तेऽवस्थिताः प्रमुखे धार्तराष्ट्राः ॥ २.६ ॥",
      "iast": "na caitad vidmaḥ kataran no garīyo yad vā jayema yadi vā no jayeyuḥ | yān eva hatvā na jijīviṣāmas te 'vasthitāḥ pramukhe dhārtarāṣṭrāḥ || 2.6 ||",
      "id": "Kami tidak tahu mana yang lebih baik bagi kami: mengalahkan mereka atau dikalahkan mereka. Sesudah membunuh mereka, kami pun tidak ingin hidup; namun putra-putra Dhṛtarāṣṭra itu berdiri di hadapan kami.",
      "ban": null,
      "status": {
        "id": "draf",
        "ban": "kosong"
      },
      "catatan": ""
    },
    {
      "no": 7,
      "devanagari": "कार्पण्यदोषोपहतस्वभावः पृच्छामि त्वां धर्मसम्मूढचेताः । यच्छ्रेयः स्यान्निश्चितं ब्रूहि तन्मे शिष्यस्तेऽहं शाधि मां त्वां प्रपन्नम् ॥ २.७ ॥",
      "iast": "kārpaṇyadoṣopahatasvabhāvaḥ pṛcchāmi tvāṃ dharmasaṃmūḍhacetāḥ | yac chreyaḥ syān niścitaṃ brūhi tan me śiṣyas te 'haṃ śādhi māṃ tvāṃ prapannam || 2.7 ||",
      "id": "Sifatku dilumpuhkan oleh kelemahan dan pikiranku bingung tentang dharma. Katakan dengan pasti apa yang terbaik bagiku. Aku murid-Mu; bimbinglah aku yang telah berlindung kepada-Mu.",
      "ban": null,
      "status": {
        "id": "draf",
        "ban": "kosong"
      },
      "catatan": ""
    },
    {
      "no": 8,
      "devanagari": "न हि प्रपश्यामि ममापनुद्याद्यच्छोकमुच्छोषणमिन्द्रियाणाम् । अवाप्य भूमावसपत्नमृद्धं राज्यं सुराणामपि चाधिपत्यम् ॥ २.८ ॥",
      "iast": "na hi prapaśyāmi mamāpanudyād yac chokam ucchoṣaṇam indriyāṇām | avāpya bhūmāv asapatnam ṛddhaṃ rājyaṃ surāṇām api cādhipatyam || 2.8 ||",
      "id": "Aku tidak melihat apa pun yang dapat menyingkirkan dukacita yang mengeringkan indraku ini, sekalipun aku memperoleh kerajaan yang makmur dan tak tertandingi di bumi, bahkan kekuasaan atas para dewa.",
      "ban": null,
      "status": {
        "id": "draf",
        "ban": "kosong"
      },
      "catatan": ""
    },
    {
      "no": 9,
      "devanagari": "सञ्जय उवाच । एवमुक्त्वा हृषीकेशं गुडाकेशः परन्तप । न योत्स्य इति गोविन्दमुक्त्वा तूष्णीं बभूव ह ॥ २.९ ॥",
      "iast": "sañjaya uvāca | evam uktvā hṛṣīkeśaṃ guḍākeśaḥ paraṃtapaḥ | na yotsya iti govindam uktvā tūṣṇīṃ babhūva ha || 2.9 ||",
      "id": "Sañjaya berkata: Setelah berkata demikian kepada Hṛṣīkeśa, Guḍākeśa, penakluk musuh, berkata kepada Govinda, “Aku tidak akan bertempur,” lalu ia terdiam.",
      "ban": null,
      "status": {
        "id": "draf",
        "ban": "kosong"
      },
      "catatan": ""
    },
    {
      "no": 10,
      "devanagari": "तमुवाच हृषीकेशः प्रहसन्निव भारत । सेनयोरुभयोर्मध्ये विषीदन्तमिदं वचः ॥ २.१० ॥",
      "iast": "tam uvāca hṛṣīkeśaḥ prahasann iva bhārata | senayor ubhayor madhye viṣīdantam idaṃ vacaḥ || 2.10 ||",
      "id": "Wahai Bhārata, kepada Arjuna yang berduka di antara kedua pasukan itu, Hṛṣīkeśa seolah-olah tersenyum lalu mengucapkan kata-kata berikut.",
      "ban": null,
      "status": {
